    {
      "id": "morph",
      "label": "Morph",
      "type": "float",
      "min": 0.0, "max": 1.0, "default": 0.5,
      "step": 0.01,
      "display": "percent"
    },
    {
      "id": "decay",
      "label": "Decay",
      "type": "float",
      "min": 0.0, "max": 1.0, "default": 0.5,
      "step": 0.01,
      "display": "percent"
    },
    {
      "id": "lpg_colour",
      "label": "LPG Colour",
